{
  "name": "bookshelf",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "bot"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:bot\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:bot": "npm run dev --workspace=bot",
    "build": "npm run build --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "deploy": "firebase deploy"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "firebase-tools": "^13.0.0",
    "serve": "^14.2.4"
  }
}
